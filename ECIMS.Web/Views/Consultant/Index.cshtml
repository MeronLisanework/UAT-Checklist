@model ECIMS.Web.Models.ViewModels.ConsultantDashboardViewModel
@{
    ViewData["Title"] = "My Projects";
    Layout = "_AuthLayout";
}

<div class="dashboard-container">
    <div class="stat-cards">
        <div class="stat-card">
            <div class="stat-card-top">
                <span>Total projects</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="7" width="18" height="13" rx="2" stroke="#7a1220" stroke-width="1.6"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2" stroke="#7a1220" stroke-width="1.6"/></svg>
            </div>
            <div class="stat-card-value">@Model.TotalCount</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-top">
                <span>In Review</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9" stroke="#b8860b" stroke-width="1.6"/><path d="M12 7v5l3 3" stroke="#b8860b" stroke-width="1.6" stroke-linecap="round"/></svg>
            </div>
            <div class="stat-card-value stat-inreview">@Model.InReviewCount</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-top">
                <span>Declined</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 4v16M5 4h11l-2 3.5L16 11H5" stroke="#7a1220" stroke-width="1.6" stroke-linejoin="round"/></svg>
            </div>
            <div class="stat-card-value stat-declined">@Model.DeclinedCount</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-top">
                <span>Completed</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 13l4 4L19 7" stroke="#1e7e34" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="stat-card-value stat-completed">@Model.CompletedCount</div>
        </div>
    </div>

    <form method="get" asp-action="Index" class="filter-bar" id="filterForm">
        <input type="hidden" name="status" id="statusInput" value="@Model.StatusFilter" />
        <div class="search-box">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="11" cy="11" r="7" stroke="#8a8a8a" stroke-width="1.6"/><path d="M21 21l-4-4" stroke="#8a8a8a" stroke-width="1.6" stroke-linecap="round"/></svg>
            <input type="text" name="search" value="@Model.Search" placeholder="Search Projects" />
        </div>

        <div class="filter-pills">
            @{
                var pills = new (string Key, string Label)[]
                {
                    ("All", "All"), ("Draft", "Draft"), ("InReview", "In Review"),
                    ("Declined", "Declined"), ("Completed", "Completed")
                };
            }
            @foreach (var pill in pills)
            {
                var activeClass = Model.StatusFilter == pill.Key ? "pill active" : "pill";
                <button type="submit" class="@activeClass" onclick="document.getElementById('statusInput').value='@pill.Key'">@pill.Label</button>
            }
        </div>
    </form>

    @if (!Model.Projects.Any())
    {
        <div class="empty-state">
            <p>No projects match your filters.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="project-table">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Branch</th>
                        <th>Status</th>
                        <th>Last Updated</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Projects)
                    {
                        <tr>
                            <td class="project-name">@p.CustomerName</td>
                            <td>@p.BranchName</td>
                            <td><span class="status-badge @p.StatusCssClass">@p.StatusLabel</span></td>
                            <td>@p.LastUpdated.ToString("MMM d, yyyy")</td>
                            <td>
                                <a asp-controller="Consultant" asp-action="ProjectDetails" asp-route-id="@p.ProjectId" class="open-link">
                                    Open <svg width="12" height="12" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 12h14M13 6l6 6-6 6" stroke="#7a1220" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination-bar">
            <span class="pagination-info">Showing @Model.ShowingFrom to @Model.ShowingTo of @Model.TotalFilteredCount projects</span>
            <div class="pagination-controls">
                <a class="page-btn @(Model.Page <= 1 ? "disabled" : "")"
                   asp-action="Index" asp-route-search="@Model.Search" asp-route-status="@Model.StatusFilter" asp-route-page="@(Model.Page - 1)">&lsaquo;</a>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a class="page-btn @(i == Model.Page ? "active" : "")"
                       asp-action="Index" asp-route-search="@Model.Search" asp-route-status="@Model.StatusFilter" asp-route-page="@i">@i</a>
                }

                <a class="page-btn @(Model.Page >= Model.TotalPages ? "disabled" : "")"
                   asp-action="Index" asp-route-search="@Model.Search" asp-route-status="@Model.StatusFilter" asp-route-page="@(Model.Page + 1)">&rsaquo;</a>
            </div>
        </div>
    }
</div>